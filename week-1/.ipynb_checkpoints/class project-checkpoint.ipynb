   "source": [
    "#parameters\n",
    "p = input(\"Principal?\")\n",
    "r = input(\"Rate?\")\n",
    "t = input(\"Time?\")\n",
    "\n",
    "#total amount to be paid\n",
    "a = p * (1 + (r / 100) * t)\n",
    "\n",
    "#interest\n",
    "i = a - p\n",
    "\n",
    "print(\"Total Amount:\", a)\n",
    "print(\"Interest to be paid:\", i)"
   ]
